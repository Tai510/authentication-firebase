};\n\n  return (\n    <div className=\"News\">\n      <NewsList news={news} />\n    </div>\n  );\n};\n\nexport default News;\n","/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/RandQuote/RandQuote.js",["128","129"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/News/NewsList.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Calculator/Calculator.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Clock/Clock.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/NotesPanel/NotesPanel.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/DashboardLayout/DashboardLayout.js",["130"],{"ruleId":"131","severity":1,"message":"132","line":6,"column":8,"nodeType":"133","messageId":"134","endLine":6,"endColumn":17},{"ruleId":"131","severity":1,"message":"135","line":8,"column":10,"nodeType":"133","messageId":"134","endLine":8,"endColumn":15},{"ruleId":"136","replacedBy":"137"},{"ruleId":"138","replacedBy":"139"},{"ruleId":"131","severity":1,"message":"140","line":13,"column":8,"nodeType":"133","messageId":"134","endLine":13,"endColumn":16},{"ruleId":"141","severity":1,"message":"142","line":42,"column":6,"nodeType":"143","endLine":42,"endColumn":23,"suggestions":"144"},{"ruleId":"145","severity":1,"message":"146","line":45,"column":16,"nodeType":"147","messageId":"148","endLine":45,"endColumn":18},{"ruleId":"141","severity":1,"message":"149","line":17,"column":6,"nodeType":"143","endLine":17,"endColumn":8,"suggestions":"150"},{"ruleId":"131","severity":1,"message":"151","line":5,"column":10,"nodeType":"133","messageId":"134","endLine":5,"endColumn":25},{"ruleId":"131","severity":1,"message":"152","line":6,"column":10,"nodeType":"133","messageId":"134","endLine":6,"endColumn":18},{"ruleId":"131","severity":1,"message":"153","line":7,"column":10,"nodeType":"133","messageId":"134","endLine":7,"endColumn":20},{"ruleId