p/dev510/authentication-firebase/src/firebase.js",[],["105","106"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Home/Card.js",["107","108","109"],"import React, { useState, useEffect } from \"react\";\nimport { makeStyles } from \"@material-ui/core/styles\";\nimport Card from \"@material-ui/core/Card\";\nimport CardActionArea from \"@material-ui/core/CardActionArea\";\nimport CardActions from \"@material-ui/core/CardActions\";\nimport CardContent from \"@material-ui/core/CardContent\";\nimport CardMedia from \"@material-ui/core/CardMedia\";\nimport Button from \"@material-ui/core/Button\";\nimport Typography from \"@material-ui/core/Typography\";\nimport { Link } from \"react-router-dom\";\n\nimport { db, auth } from \"../../firebase\";\nimport firebase from \"firebase/app\";\n\nconst useStyles = makeStyles({\n  root: {\n    maxWidth: 345,\n    marginTop: 30,\n    marginLeft: 30,\n    marginRight: 30,\n  },\n});\n\nexport default function ImgMediaCard() {\n  const [message, setMessage] = useState();\n  const classes = useStyles();\n\n  const [notify, setNotify] = useState(0);\n  const [data, setData] = useState([]);\n\n  useEffect(() => {\n    db.collection(auth.currentUser.uid)\n      .orderBy(\"timestamp\", \"asc\")\n      .onSnapshot((snapshot) => {\n        setData(\n          snapshot.docs.map((doc) => ({ id: doc.id, item: doc.data().item }))\n        );\n        setNotify(parseInt(data.length));\n        // console.log(\"Length :\", notify);\n        notiMessage();\n      });\n  }, [message, notify]);\n\n  const notiMessage = () => {\n    if (notify == 0) {\n      setMessage(\n        \"You have no Todos. Make sure to use Todo App and stay organized\"\n      );\n    } else {\n      setMessage(`You have ${notify} Incompleted Tasks. Lets get it done!!! 💯`);\n    }\n  };\n\n  return (\n    <Card className={classes.root}>\n      <CardActionArea>\n        <CardMedia\n          component=\"img\"\n          alt=\"Contemplative Reptile\"\n          height=\"140\"\n          image=\"https://images.unsplash.com/photo-1523634921619-37ce98c1877f?ixid=MXwxMjA3fDB8MHxzZWFyY2h8Mnx8dG9kb3xlbnwwfHwwfA%3D%3D&ixlib=rb-1.2.1&w=1000&q=80\"\n          title=\"Contemplative Reptile\"\n        />\n        <CardContent>\n          <Typography gutterBottom variant=\"h5\" component=\"h2\">\n            My Todo\n          </Typography>\n          <Typography variant=\"body2\" color=\"textSecondary\" component=\"p\">\n            {message}\n          </Typography>\n        </CardContent>\n      </CardActionArea>\n      <CardActions>\n        <Button size=\"small\" color=\"primary\">\n          <Link to=\"/todos\">Go to Todo</Link>\n        </Button>\n      </CardActions>\n    </Card>\n  );\n}\n","/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Weather/Weather.js",["110"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Calendar/Calendar.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Home/Home.js",["111","112","113"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Weather/WeatherInfo.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/index.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Signup.js",["114","115","116","117","118"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Dashboard.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Todo/Todo.js",["119","120","121"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/PrivateRoute.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/ForgotPassword.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Todo/TodoForm.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Todo/TodoList.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Todo/TodoItem.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/News/News.js",["122","123"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/RandQuote/RandQuote.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/News/NewsList.js",["124","125"],"import React from \"react\";\n\nconst NewsList = ({ news }) => {\n  return (\n    <div>\n      <div className=\"news-img-div\">\n        <img src={news.urlToImage}></img>\n      </div>\n      <div className=\"news-details-div\">\n        <p className=\"news-title\">\n          {news.title}{\" \"}\n          <span>\n            <a\n              style={{ display: \"table-cell\" }}\n              target=\"_blank\"\n              href={news.url}\n            >\n              (See Full Story)\n            </a>\n          </span>\n        </p>\n        <p className=\"news-description\">{news.description}</p>\n      </div>\n    </div>\n  );\n};\n\nexport default NewsList;\n","/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Calculator/Calculator.js",[],{"ruleId":"126","severity":1,"message":"127","line":6,"column":8,"nodeType":"128","messageId":"129","endLine":6,"endColumn":14},{"ruleId":"126","severity":1,"message":"130","line":9,"column":10,"nodeType":"128","messageId":"129","endLine":9,"endColumn":15},{"ruleId":"126","severity":1,"message":"131","line":10,"column":11,"nodeType":"128","messageId":"129","endLine":10,"endColumn":22},{"ruleId":"126","severity":1,"message":"132","line":13,"column":9,"nodeType":"128","messageId":"129","endLine":13,"endColumn":18},{"ruleId":"133","replacedBy":"134"},{"ruleId":"135","replacedBy":"136"},{"ruleId":"126","severity":1,"message":"137","line":13,"column":8,"nodeType":"128","messageId":"129","endLine":13,"endColumn":16},{"ruleId":"138","severity":1,"message":"139","line":42,"column":6,"nodeType":"140","endLine":42,"endColumn":23,"suggestions":"141"},{"ruleId":"142","severity":1,