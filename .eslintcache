xableWarningCount":0},{"filePath":"107","messages":"108","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"68"},{"filePath":"109","messages":"110","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"68"},{"filePath":"111","messages":"112","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/App.js",["113"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Login.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/UpdateProfile.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/contexts/AuthContext.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Nav/NavBar.js",["114"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/firebase.js",[],["115","116"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Home/Card.js",["117","118","119"],"import React, { useState, useEffect } from \"react\";\nimport { makeStyles } from \"@material-ui/core/styles\";\nimport Card from \"@material-ui/core/Card\";\nimport CardActionArea from \"@material-ui/core/CardActionArea\";\nimport CardActions from \"@material-ui/core/CardActions\";\nimport CardContent from \"@material-ui/core/CardContent\";\nimport CardMedia from \"@material-ui/core/CardMedia\";\nimport Button from \"@material-ui/core/Button\";\nimport Typography from \"@material-ui/core/Typography\";\nimport { Link } from \"react-router-dom\";\n\nimport { db, auth } from \"../../firebase\";\nimport firebase from \"firebase/app\";\n\nconst useStyles = makeStyles({\n  root: {\n    maxWidth: 345,\n    marginTop: 30,\n    marginLeft: 30,\n    marginRight: 30,\n  },\n});\n\nexport default function ImgMediaCard() {\n  const [message, setMessage] = useState();\n  const classes = useStyles();\n\n  const [notify, setNotify] = useState(0);\n  const [data, setData] = useState([]);\n\n  useEffect(() => {\n    db.collection(auth.currentUser.uid)\n      .orderBy(\"timestamp\", \"asc\")\n      .onSnapshot((snapshot) => {\n        setData(\n          snapshot.docs.map((doc) => ({ id: doc.id, item: doc.data().item }))\n        );\n        setNotify(parseInt(data.length));\n        // console.log(\"Length :\", notify);\n        notiMessage();\n      });\n  }, [message, notify]);\n\n  const notiMessage = () => {\n    if (notify == 0) {\n      setMessage(\n        \"You have no Todos. Make sure to use Todo App and stay organized\"\n      );\n    } else {\n      setMessage(`You have ${notify} Incompleted Tasks. Lets get it done!!! 💯`);\n    }\n  };\n\n  return (\n    <Card className={classes.root}>\n      <CardActionArea>\n        <CardMedia\n          component=\"img\"\n          alt=\"Contemplative Reptile\"\n          height=\"140\"\n          image=\"https://images.unsplash.com/photo-1523634921619-37ce98c1877f?ixid=MXwxMjA3fDB8MHxzZWFyY2h8Mnx8dG9kb3xlbnwwfHwwfA%3D%3D&ixlib=rb-1.2.1&w=1000&q=80\"\n          title=\"Contemplative Reptile\"\n        />\n        <CardContent>\n          <Typography gutterBottom variant=\"h5\" component=\"h2\">\n            My Todo\n          </Typography>\n          <Typography variant=\"body2\" color=\"textSecondary\" component=\"p\">\n            {message}\n          </Typography>\n        </CardContent>\n      </CardActionArea>\n      <CardActions>\n        <Button size=\"small\" color=\"primary\">\n          <Link to=\"/todos\">Go to Todo</Link>\n        </Button>\n      </CardActions>\n    </Card>\n  );\n}\n","/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Weather/Weather.js",["120"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Calendar/Calendar.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/compone