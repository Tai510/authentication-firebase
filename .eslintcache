07","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"108","messages":"109","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"68"},{"filePath":"110","messages":"111","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"68"},{"filePath":"112","messages":"113","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/App.js",["114"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Login.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/UpdateProfile.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/contexts/AuthContext.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Nav/NavBar.js",["115"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/firebase.js",[],["116","117"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Home/Card.js",["118","119","120"],"import React, { useState, useEffect } from \"react\";\nimport { makeStyles } from \"@material-ui/core/styles\";\nimport Card from \"@material-ui/core/Card\";\nimport CardActionArea from \"@material-ui/core/CardActionArea\";\nimport CardActions from \"@material-ui/core/CardActions\";\nimport CardContent from \"@material-ui/core/CardContent\";\nimport CardMedia from \"@material-ui/core/CardMedia\";\nimport Button from \"@material-ui/core/Button\";\nimport Typography from \"@material-ui/core/Typography\";\nimport { Link } from \"react-router-dom\";\n\nimport { db, auth } from \"../../firebase\";\nimport firebase from \"firebase/app\";\n\nconst useStyles = makeStyles({\n  root: {\n    maxWidth: 345,\n    marginTop: 30,\n    marginLeft: 30,\n    marginRight: 30,\n  },\n});\n\nexport default function ImgMediaCard() {\n  const [message, setMessage] = useState();\n  const classes = useStyles();\n\n  const [notify, setNotify] = useState(0);\n  const [data, setData] = useState([]);\n\n  useEffect(() => {\n    db.collection(auth.currentUser.uid)\n      .orderBy(\"timestamp\", \"asc\")\n      .onSnapshot((snapshot) => {\n        setData(\n          snapshot.docs.map((doc) => ({ id: doc.id, item: doc.data().item }))\n        );\n        setNotify(parseInt(data.length));\n        // console.log(\"Length :\", notify);\n        notiMessage();\n      });\n  }, [message, notify]);\n\n  const notiMessage = () => {\n    if (notify == 0) {\n      setMessage(\n        \"You have no Todos. Make sure to use Todo App and stay organized\"\n      );\n    } else {\n      setMessage(`You have ${notify} Incompleted Tasks. Lets get it done!!! 💯`);\n    }\n  };\n\n  return (\n    <Card className={classes.root}>\n      <CardActionArea>\n        <CardMedia\n          component=\"img\"\n          alt=\"Contemplative Reptile\"\n          height=\"140\"\n          image=\"https://images.unsplash.com/photo-1523634921619-37ce98c1877f?ixid=MXwxMjA3fDB8MHxzZWFyY2h8Mnx8dG9kb3xlbnwwfHwwfA%3D%3D&ixlib=rb-1.2.1&w=1000&q=80\"\n          title=\"Contemplative Reptile\"\n        />\n        <CardContent>\n          <Typography gutterBottom variant=\"h5\" component=\"h2\">\n            My Todo\n          </Typography>\n          <Typography variant=\"body2\" color=\"textSecondary\" component=\"p\">\n            {message}\n          </Typography>\n        </CardContent>\n      </CardActionArea>\n      <CardActions>\n        <Button size=\"small\" color=\"primary\">\n          <Link to=\"/todos\">Go to Todo</Link>\n        </Button>\n      </CardActions>\n    </Card>\n  );\n}\n","/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Weather/Weather.js",["121"],"import React, { useState, useEffect } from \"react\";\nimport \"./Weather.css\";\nimport WeatherInfo from \"./WeatherInfo\";\n\nconst Weather = () => {\n  // 1. State\n  const [town, setTown] = useState(\"\");\n  const [error, setError] = useState(\"\");\n\n  // 2. API keys\n  const geoKey = process.env.REACT_APP_GEO_API;\n\n  // 3. Run when component first loads\n  useEffect(() => {\n    getLocation();\n  }, []);\n\n  // 4. Get user's current location\n  const getLocation = () => {\n    navigator.geolocation.getCurrentPosition(\n      function (position) {\n        const { latitude, longitude } = position.coords;\n\n        fetch(\n          `https://api.opencagedata.com/geocode/v1/json?q=${latitude}+${longitude}&key=${geoKey}`\n        )\n          .then((res) => res.json())\n          .then((data) => {\n            console.log(\"Location data:\", data);\n\n            const components = data.results?.[0]?.components;\n\n            let city =\n              components?.city ||\n              components?.town ||\n              components?.village ||\n              components?.municipality ||\n              components?.hamlet ||\n              components?.county;\n\n            if (city === \"El Verano\") {\n              city = \"Sonoma\";\n            }\n\n            const state = components?.state;\n\n            setTown(`${city}, ${state}`);\n          });\n      },\n      function (error) {\n        console.log(\"Location error:\", error);\n        setError(\"Unable to get your location.\");\n      }\n    );\n  };\n\n  // 5. What shows on the page\n  return (\n    <div>\n      {error && <p>{error}</p>}\n\n      <WeatherInfo town={town} />\n    </div>\n  );\n};\n\nexport default Weather;\n","/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Calendar/Calendar.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Home/Home.js",["122","123","124"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Weather/WeatherInfo.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/index.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Signup.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Dashboard.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Todo/Todo.js",["125","126","127"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/PrivateRoute.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/ForgotPassword.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Todo/TodoForm.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Todo/TodoList.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Todo/TodoItem.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/News/News.js",["128","129"],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/RandQuote/RandQuote.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/News/NewsList.js",["130","131"],"import React from \"react\";\n\nconst NewsList = ({ news }) => {\n  return (\n    <div>\n      <div className=\"news-img-div\">\n        <img src={news.urlToImage}></img>\n      </div>\n      <div className=\"news-details-div\">\n        <p className=\"news-title\">\n          {news.title}{\" \"}\n          <span>\n            <a\n              style={{ display: \"table-cell\" }}\n              target=\"_blank\"\n              href={news.url}\n            >\n              (See Full Story)\n            </a>\n          </span>\n        </p>\n        <p className=\"news-description\">{news.description}</p>\n      </div>\n    </div>\n  );\n};\n\nexport default NewsList;\n","/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Calculator/Calculator.js",[],"/Users/tashiwoeser/Desktop/dev510/authentication-firebase/src/components/Clock/Clock.js",[],"/Users/tashiwoeser/Desktop/dev510/authentica